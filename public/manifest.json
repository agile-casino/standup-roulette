{
  "manifest_version": 3,
  "name": "Standup Roulette",
  "version": "4.18.1",
  "description": "Automate standup roulette selection on Azure DevOps sprint boards.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://dev.azure.com/*", "https://*.visualstudio.com/*"],
      "js": ["index.user.js"],
      "run_at": "document_idle"
    }
  ]
}
