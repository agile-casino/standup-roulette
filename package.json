{
  "name": "standup-roulette",
  "version": "4.18.3",
  "description": "standup-roulette",
  "main": "src/index.tsx",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:watch": "vite build --watch",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "dev": "vite",
    "lint": "prettier --check \"**/*.{md,yml}\" && biome check && knip",
    "lint:fix": "prettier --write \"**/*.{md,yml}\" && biome check --write && knip --fix",
    "prune": "ts-prune",
    "sync": "node scripts/sync-manifest.js",
    "tcm": "tcm src/**/*.module.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "zip": "node scripts/zip-extension.js",
    "prepare": "lefthook install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agile-casino/standup-roulette.git"
  },
  "author": "archerax",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/agile-casino/standup-roulette/issues"
  },
  "homepage": "https://github.com/agile-casino/standup-roulette#readme",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "renovate": {
    "bumpVersion": "patch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/recommended": "^1.0.13",
    "@types/archiver": "^8.0.0",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tampermonkey": "^5.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "archiver": "^8.0.0",
    "happy-dom": "^20.11.0",
    "knip": "^6.27.0",
    "lefthook": "^2.1.10",
    "postcss": "^8.5.20",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.9.5",
    "ts-prune": "^0.10.3",
    "typed-css-modules": "^0.9.1",
    "typescript": "^7.0.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.1.5",
    "vite-bundle-analyzer": "^1.3.9",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-css-injected-by-js": "^5.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tabler/icons-react": "^3.45.0",
    "buffer": "^6.0.3",
    "crc": "^4.3.2",
    "immer": "^11.1.15",
    "react": "^19.2.7",
    "react-custom-roulette": "^1.4.1",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  }
